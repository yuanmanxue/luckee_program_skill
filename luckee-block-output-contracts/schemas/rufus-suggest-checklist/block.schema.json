{
  "_comment": "rufus_suggest_checklist — 字段约束速查（详情见 references/rufus-suggest-checklist.md §3）",

  "type":        "rufus_suggest_checklist（固定值）",
  "version":     "1.0（固定值）",
  "source":      "llm_output（固定值）",
  "title":       "string（可选）",
  "description": "string（可选）",
